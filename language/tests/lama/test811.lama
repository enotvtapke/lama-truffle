printf ("%d\n", length (makeString (5)));
printf ("%d\n", compare ("a", "b"));
printf ("%d\n", compare (42, 42));
printf ("%d\n", flatCompare (1, 2));
printf ("%d\n", flatCompare (3, 3));
printf ("%d\n", compare (tagHash ("a"), tagHash ("a")));
printf ("%d\n", regexpMatch (regexp ("^a+$"), "aaa", 0))
