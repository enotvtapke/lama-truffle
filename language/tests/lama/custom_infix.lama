infix <+> at + (a, b) { a + b * 10 }

infixr ** before * (a, b) {
  if b == 0 then 1
  elif b == 1 then a
  else a * (a ** (b - 1))
  fi
}

infixl >> after := (a, b) { b(a) }

fun double(n) { n * 2 }
fun inc(n) { n + 1 }

-- at: inherits left-associativity from +
write(1 <+> 2);
write(1 <+> 2 <+> 3);
write(1 <+> 2 + 3);

-- before *: lower precedence than *
write(2 ** 10);
write(2 ** 3 * 2);
write(2 * 2 ** 3);

-- infixr: right-associative chaining
write(2 ** 3 ** 2);

-- after :=: pipe operator
write(5 >> double);
write(5 >> double >> inc)
